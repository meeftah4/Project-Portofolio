# Spring Boot backend environment template
# Copy values to your runtime environment (PowerShell/CMD/Linux/container secrets)

APP_DB_URL=jdbc:postgresql://localhost:5432/belajardb
APP_DB_USERNAME=postgres
APP_DB_PASSWORD=rahasia

# Use a long random secret (at least 64 chars recommended)
APP_JWT_SECRET=replace-with-long-random-secret-please-change-me-1234567890
APP_JWT_EXPIRATION_HOURS=24
APP_REFRESH_TOKEN_EXPIRATION_DAYS=14

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Bootstrap admin account (set false after first setup in production)
APP_ADMIN_BOOTSTRAP_ENABLED=true
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@local.dev
APP_ADMIN_PASSWORD=Admin12345
APP_ADMIN_FULL_NAME=System Administrator
